---
import { LINKS } from '../data/site';
import { nextEvent, upcomingEvents, cleanTitle, formatDate, formatTime, dateParts, formatShortDate } from '../lib/events';
import Icon from './Icon.astro';

const later = upcomingEvents.slice(1, 4);
const badge = nextEvent ? dateParts(nextEvent.start) : null;
---

<section id="next" class="shell scroll-mt-24 pb-20 md:pb-28">
  <div class="reveal panel relative overflow-hidden p-7 md:p-12">
    <!-- Gradient hairline along the top edge: the card's only decoration. -->
    <div
      class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-violet to-transparent"
      aria-hidden="true"
    >
    </div>

    {
      nextEvent && badge ? (
        <div class="grid gap-9 md:grid-cols-[auto_1fr] md:gap-12">
          <div class="flex shrink-0 items-center gap-4 md:flex-col md:items-start md:gap-0">
            <p class="label mb-0 md:mb-4">Next up</p>
            <div class="flex items-baseline gap-2 md:flex-col md:gap-1">
              <span class="font-display text-[clamp(3rem,7vw,4.75rem)] leading-none font-semibold">
                {badge.day}
              </span>
              <span class="font-mono text-lg tracking-[0.2em] text-blue">{badge.month}</span>
            </div>
          </div>

          <div class="min-w-0">
            <h2 class="text-[clamp(1.6rem,3.4vw,2.5rem)] leading-[1.1]">
              {cleanTitle(nextEvent.title)}
            </h2>

            <p class="mt-5 flex flex-wrap items-center gap-x-5 gap-y-2 font-mono text-[0.8125rem] text-muted">
              <span class="inline-flex items-center gap-2">
                <Icon name="calendar" class="h-4 w-4 text-faint" />
                {formatDate(nextEvent.start)}
              </span>
              <span class="inline-flex items-center gap-2">
                <Icon name="clock" class="h-4 w-4 text-faint" />
                {nextEvent.end
                  ? `${formatTime(nextEvent.start)}–${formatTime(nextEvent.end)}`
                  : formatTime(nextEvent.start)}
              </span>
              <span class="inline-flex items-center gap-2">
                <Icon name="pin" class="h-4 w-4 text-faint" />
                Lisbon
              </span>
            </p>

            {nextEvent.excerpt && (
              <p class="mt-6 max-w-2xl leading-relaxed text-muted">{nextEvent.excerpt}</p>
            )}

            <div class="mt-8 flex flex-wrap items-center gap-3">
              <a href={nextEvent.url} target="_blank" rel="noopener" class="btn btn-primary">
                RSVP on Meetup
                <Icon name="arrowUpRight" class="h-4 w-4" />
              </a>
              <span class="font-mono text-[0.75rem] text-faint">Free · seats are limited</span>
            </div>

            {later.length > 0 && (
              <ul class="mt-9 space-y-2 border-t border-rule pt-5">
                <li class="label mb-1">Also scheduled</li>
                {later.map((event) => (
                  <li>
                    <a
                      href={event.url}
                      target="_blank"
                      rel="noopener"
                      class="group flex flex-wrap items-baseline gap-x-4 gap-y-1 py-1 text-sm transition-colors hover:text-blue"
                    >
                      <span class="font-mono text-[0.75rem] text-faint">
                        {formatShortDate(event.start)}
                      </span>
                      <span class="text-muted transition-colors group-hover:text-bone">
                        {cleanTitle(event.title)}
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      ) : (
        /* No event in the feed. Designed as a real state, not a hole in the page. */
        <div class="grid gap-9 md:grid-cols-[auto_1fr] md:gap-12">
          <div class="flex shrink-0 items-center gap-4 md:flex-col md:items-start md:gap-0">
            <p class="label mb-0 md:mb-4">Next up</p>
            <span class="font-display text-[clamp(3rem,7vw,4.75rem)] leading-none font-semibold text-faint/60">
              //
            </span>
          </div>

          <div>
            <h2 class="text-[clamp(1.6rem,3.4vw,2.5rem)] leading-[1.1]">
              The next date isn't announced yet.
            </h2>
            <p class="mt-5 max-w-2xl leading-relaxed text-muted">
              We run a meetup roughly every month. Join the group on Meetup and you'll be notified the
              moment the next one opens for RSVPs. This page updates automatically too.
            </p>
            <div class="mt-8 flex flex-wrap items-center gap-3">
              <a href={LINKS.meetup} target="_blank" rel="noopener" class="btn btn-primary">
                Get notified on Meetup
                <Icon name="arrowUpRight" class="h-4 w-4" />
              </a>
              <a href="#talks" class="btn btn-ghost">See past talks</a>
            </div>
          </div>
        </div>
      )
    }
  </div>
</section>
