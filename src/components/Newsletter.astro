---
import { NEWSLETTER, LINKS } from '../data/site';
import Icon from './Icon.astro';

// A native form POST: no JavaScript, no API key, nothing secret in the repo.
const live = Boolean(NEWSLETTER.formUrl);
---

<section id="newsletter" class="shell scroll-mt-24 pb-20 md:pb-28">
  <div class="reveal panel relative overflow-hidden p-7 md:p-11">
    <div
      class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-blue to-transparent"
      aria-hidden="true"
    >
    </div>

    <div class="grid items-center gap-9 md:grid-cols-[1.1fr_1fr] md:gap-14">
      <div>
        <p class="label flex items-center gap-2.5">
          <Icon name="mail" class="h-4 w-4 text-blue" />
          Newsletter
        </p>
        <h2 class="mt-5 text-[clamp(1.5rem,3vw,2.15rem)] leading-[1.12]">
          One email a month.<br class="hidden sm:block" />
          <span class="gradient-text">Nothing else.</span>
        </h2>
        <p class="mt-4 max-w-md text-[0.9375rem] leading-relaxed text-muted">
          The next meetup, a recap of the last one, and what our community is reading. No spam, no
          sponsors in your inbox, unsubscribe in one click.
        </p>
      </div>

      {
        live ? (
          <form
            action={NEWSLETTER.formUrl!}
            method="POST"
            target="_blank"
            rel="noopener"
            class="w-full"
          >
            <label for="newsletter-email" class="label mb-3 block">
              Your email
            </label>
            <div class="flex flex-col gap-3 sm:flex-row">
              <input
                id="newsletter-email"
                type="email"
                name={NEWSLETTER.emailField}
                required
                autocomplete="email"
                placeholder="you@company.com"
                class="min-w-0 flex-1 rounded-full border border-rule-strong bg-ink/60 px-5 py-3 font-mono text-[0.8125rem] text-bone placeholder:text-faint focus:border-blue focus:outline-none"
              />
              <button type="submit" class="btn btn-primary justify-center">
                Subscribe
                <Icon name="arrow" class="h-4 w-4" />
              </button>
            </div>
            <p class="mt-3 font-mono text-[0.6875rem] text-faint">
              Handled by Brevo. We never share your address.
            </p>
          </form>
        ) : (
          /* Not wired up yet. Say so plainly instead of shipping a dead form. */
          <div class="panel bg-ink/40 p-6">
            <p class="label mb-3 inline-block rounded-full border border-rule px-2.5 py-1 text-[0.5625rem]">
              Opening soon
            </p>
            <p class="text-[0.9375rem] leading-relaxed text-muted">
              We're setting the newsletter up now. In the meantime, joining the Meetup group gets
              you every event announcement, or drop us a line and we'll add you to the first send.
            </p>
            <div class="mt-6 flex flex-wrap gap-3">
              <a href={LINKS.meetup} target="_blank" rel="noopener" class="btn btn-ghost">
                <Icon name="users" class="h-4 w-4" />
                Join on Meetup
              </a>
              <a href={LINKS.emailNewsletter} class="btn btn-ghost">
                <Icon name="mail" class="h-4 w-4" />
                Email us
              </a>
            </div>
          </div>
        )
      }
    </div>
  </div>
</section>
