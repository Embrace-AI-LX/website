---
import { TEAM } from '../data/team';
import SectionHead from './SectionHead.astro';
import Icon from './Icon.astro';

const initials = (name: string) =>
  name
    .split(' ')
    .filter((w) => /^[A-Z]/.test(w))
    .slice(0, 2)
    .map((w) => w[0])
    .join('');
---

<section id="team" class="shell scroll-mt-24 py-20 md:py-28">
  <SectionHead
    index="05"
    label="Who runs it"
    title="International team. Portugal-based."
    lede="Embrace:AI is run by volunteers in their own time. Nobody takes a salary from it."
  />

  <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {
      TEAM.map((member) => (
        <article class="panel panel-hover reveal flex flex-col p-7">
          <div class="flex items-center gap-4">
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-rule-strong bg-gradient-to-br from-indigo/25 to-violet/25 font-display text-sm font-semibold">
              {initials(member.name)}
            </span>
            <div class="min-w-0">
              <h3 class="text-lg leading-tight">{member.name}</h3>
              <p class="label mt-1.5">{member.role}</p>
            </div>
          </div>
          <p class="mt-6 text-[0.9375rem] leading-relaxed text-muted">{member.focus}</p>
          <p class="mt-auto flex items-center gap-3 border-t border-rule pt-4 font-mono text-[0.75rem] text-faint">
            <span>
              {member.flag} {member.base}
            </span>
            {member.linkedin && (
              <a
                href={member.linkedin}
                target="_blank"
                rel="noopener"
                class="ml-auto inline-flex items-center gap-1.5 transition-colors hover:text-blue"
                aria-label={`${member.name} on LinkedIn`}
              >
                <Icon name="linkedin" class="h-3.5 w-3.5" />
                LinkedIn
              </a>
            )}
          </p>
        </article>
      ))
    }
  </div>
</section>
